---
import Layout from '../layouts/Layout.astro';
import DoctorSlider from '../components/DoctorSlider.astro';
import ImageSlider from '../components/ImageSlider.astro';
import { bloodDonationImages } from '../data/blood-donation-images';
import { womenCampImages } from '../data/women-camp-images';
---

<Layout
  title="Smart Health Clinic | Best Clinic in Kathmandu"
  description="Trusted healthcare services in Pepsicola Kathmandu. Consult doctors, diagnostics, and more."
>
  <!-- HERO -->
  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="absolute inset-0">
      <img src="/images/clinic-hero1.png" class="h-full w-full object-cover" />
      <div
        class="absolute inset-0 bg-linear-to-br from-clinic-slate/90 via-clinic-slate/80 to-clinic-teal/70"
      >
      </div>
    </div>

    <div class="absolute top-6 right-6 z-20 flex items-center gap-4">
      <span
        class="text-white text-sm font-bold tracking-widest uppercase"
        data-t="home_hero_follow"
      >
        Follow Us:
      </span>

      <div class="flex gap-2">
        <a
          href="https://www.facebook.com/shnclinic/"
          target="_blank"
          aria-label="Facebook"
          class="flex items-center justify-center transition-transform hover:scale-110"
        >
          <img
            src="https://www.svgrepo.com/show/494273/facebook-round.svg"
            alt="Facebook"
            class="h-6 w-6 invert"
          />
        </a>

        <a
          href="https://www.instagram.com/smarthealthclinic_"
          target="_blank"
          aria-label="Instagram"
          class="flex items-center justify-center transition-transform hover:scale-110"
        >
          <img
            src="https://www.svgrepo.com/show/474324/instagram.svg"
            alt="Instagram"
            class="h-6 w-6 invert"
          />
        </a>

        <a
          href="https://www.youtube.com/@SmartHealthClinic-c6t"
          target="_blank"
          aria-label="YouTube"
          class="flex items-center justify-center transition-transform hover:scale-110"
        >
          <img
            src="https://www.svgrepo.com/show/513089/youtube-168.svg"
            alt="YouTube"
            class="h-6 w-6 invert"
          />
        </a>

        <a
          href="https://www.google.com/maps?cid=16583436132790178084&g_mp=CiVnb29nbGUubWFwcy5wbGFjZXMudjEuUGxhY2VzLkdldFBsYWNlEAMYASAF&hl=en&gl=US&source=embed"
          target="_blank"
          aria-label="GoogleMaps"
          class="flex items-center justify-center transition-transform hover:scale-110"
        >
          <img
            src="https://www.svgrepo.com/show/532539/location-pin.svg"
            alt="GoogleMaps"
            class="h-6 w-6 invert"
          />
        </a>
      </div>
    </div>

    <div class="relative container px-4 text-white w-full">
      <h1 class="text-4xl md:text-6xl font-black leading-tight drop-shadow-2xl">
        <!-- Line 1: Trusted -->
        <span class="block" data-t="home_hero_title_1">
          Smart Health Clinic – Trusted Specialist Healthcare in Pepsicola
        </span>

        <!-- Line 2: Specialist Healthcare (Different Color) -->
        <span class="block text-clinic-teal" data-t="home_hero_title_2"> </span>

        <!-- Line 3: in Pepsicola -->
        <span class="block" data-t="home_hero_title_3"></span>
      </h1>

      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-4 text-sm font-bold text-slate-100">
        <!-- Tag 1 -->
        <div class="flex items-center gap-2">
          <span
            class="h-2 w-2 shrink-0 rounded-full bg-clinic-teal shadow-[0_0_8px_rgba(var(--color-clinic-teal),0.6)]"
          ></span>
          <span data-t="home_hero_tag1">Modern Care</span>
        </div>

        <!-- Tag 2 -->
        <div class="flex items-center gap-2">
          <span
            class="h-2 w-2 shrink-0 rounded-full bg-clinic-teal shadow-[0_0_8px_rgba(var(--color-clinic-teal),0.6)]"
          ></span>
          <span data-t="home_hero_tag2">Experienced Doctors</span>
        </div>

        <!-- Tag 3 -->
        <div class="flex items-center gap-2">
          <span
            class="h-2 w-2 shrink-0 rounded-full bg-clinic-teal shadow-[0_0_8px_rgba(var(--color-clinic-teal),0.6)]"
          ></span>
          <span data-t="home_hero_tag3">Compassionate Service</span>
        </div>
      </div>

      <div class="relative z-10 py-5">
        <div class="flex flex-wrap items-start gap-4 -ml-2">
          <!-- Item 1 -->
          <div class="flex flex-col items-start text-left group w-20">
            <div
              class="h-16 w-16 bg-clinic-teal rounded-full flex items-center justify-center border-2 border-white shadow-lg transition-transform group-hover:scale-110 overflow-hidden"
            >
              <img
                src="https://www.svgrepo.com/show/484074/doctor.svg"
                alt="Doctor"
                class="h-10 w-10 invert"
              />
            </div>
            <p
              class="mt-2 text-[10px] font-black tracking-tighter text-white uppercase leading-tight drop-shadow-md"
              data-t="home_tag_spec"
            >
              Experienced Specialists
            </p>
          </div>

          <!-- Item 2 -->
          <div class="flex flex-col items-start text-left group w-20">
            <div
              class="h-16 w-16 bg-clinic-teal rounded-full flex items-center justify-center border-2 border-white shadow-lg transition-transform group-hover:scale-110 overflow-hidden"
            >
              <img
                src="https://www.svgrepo.com/show/347004/hand-heart.svg"
                alt="Care"
                class="h-10 w-10 invert"
              />
            </div>
            <p
              class="mt-2 text-[10px] font-black tracking-tighter text-white uppercase leading-tight drop-shadow-md"
              data-t="home_tag_patient"
            >
              Patient Focused Care
            </p>
          </div>

          <!-- Item 3 -->
          <div class="flex flex-col items-start text-left group w-20">
            <div
              class="h-16 w-16 bg-clinic-teal rounded-full flex items-center justify-center border-2 border-white shadow-lg transition-transform group-hover:scale-110 overflow-hidden"
            >
              <img
                src="https://www.svgrepo.com/show/181792/microscope-medical.svg"
                alt="Care"
                class="h-10 w-10 invert"
              />
            </div>
            <p
              class="mt-2 text-[10px] font-black tracking-tighter text-white uppercase leading-tight drop-shadow-md"
              data-t="home_tag_diag"
            >
              Advanced Diagnostics
            </p>
          </div>

          <!-- Item 4 -->
          <div class="flex flex-col items-start text-left group w-20">
            <div
              class="h-16 w-16 bg-clinic-teal rounded-full flex items-center justify-center border-2 border-white shadow-lg transition-transform group-hover:scale-110 overflow-hidden"
            >
              <img
                src="https://www.svgrepo.com/show/281628/chiropractic-physiotherapy.svg"
                alt="Care"
                class="h-10 w-10 invert"
              />
            </div>
            <p
              class="mt-2 text-[10px] font-black tracking-tighter text-white uppercase leading-tight drop-shadow-md"
              data-t="home_tag_physio"
            >
              Physiotherapy & Rehabilitation
            </p>
          </div>

          <!-- Item 5 -->
          <div class="flex flex-col items-start text-left group w-20">
            <div
              class="h-16 w-16 bg-clinic-teal rounded-full flex items-center justify-center border-2 border-white shadow-lg transition-transform group-hover:scale-110 overflow-hidden"
            >
              <img
                src="https://www.svgrepo.com/show/421930/health-medical-medical-report.svg"
                alt="Care"
                class="h-10 w-10 invert"
              />
            </div>
            <p
              class="mt-2 text-[10px] font-black tracking-tighter text-white uppercase leading-tight drop-shadow-md"
              data-t="home_tag_checkup"
            >
              Health Checkups
            </p>
          </div>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row items-start lg:items-center gap-4 py-8">
        <div
          class="flex flex-col md:flex-row items-start md:items-center bg-[#0a1e29]/80 backdrop-blur-sm border border-clinic-teal/30 rounded-2xl overflow-hidden"
        >
          <div
            class="flex items-center gap-3 px-6 py-4 border-b md:border-b-0 md:border-r border-clinic-teal/30 w-full md:w-auto justify-start"
          >
            <div class="bg-white rounded-full p-1.5 shrink-0">
              <img
                src="https://www.svgrepo.com/show/526086/phone.svg"
                alt="Phone"
                class="h-5 w-5"
              />
            </div>
            <span class="text-white font-bold text-lg whitespace-nowrap">01-5924005</span>
          </div>

          <div
            class="flex items-center gap-3 px-6 py-4 border-b md:border-b-0 md:border-r border-clinic-teal/30 w-full md:w-auto justify-start"
          >
            <img
              src="https://www.svgrepo.com/show/522167/location.svg"
              alt="Location"
              class="h-6 w-6 invert shrink-0"
            />
            <div class="text-white text-sm leading-tight text-left">
              <p class="font-semibold">Kandaghari, Pepsicola,</p>
              <p class="font-semibold">Kathmandu</p>
            </div>
          </div>

          <div class="flex items-center gap-3 px-6 py-4 w-full md:w-auto justify-start">
            <img
              src="https://www.svgrepo.com/show/415803/website-ui-web.svg"
              alt="Web"
              class="h-6 w-6 invert shrink-0"
            />
            <span class="text-white font-semibold text-sm text-left">smarthealthclinic.com.np</span>
          </div>
        </div>

        <a
          href="https://vendor.smarthealthnepal.com/"
          target="_blank"
          class="flex self-start items-center gap-3 bg-clinic-teal hover:bg-teal-500 text-white px-8 py-5 rounded-full font-bold shadow-lg transition-all transform hover:scale-105"
        >
          <img
            src="https://www.svgrepo.com/show/533396/calendar-lines-pen.svg"
            alt="Calendar"
            class="h-6 w-6 invert"
          />
          <span class="uppercase tracking-wider">Book Appointment</span>
        </a>
      </div>
    </div>
  </section>

  <!-- BASIC INFO -->
  <section class="relative -mt-12 z-10">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-5 bg-white rounded-3xl shadow-xl p-6 text-center">
        <div>
          <div class="text-xl">🏥</div>
          <p data-t="home_info_name_label" class="text-sm text-gray-500">Clinic Name</p>
          <p data-t="home_info_name" class="font-bold">Smart Health Clinic</p>
        </div>

        <div>
          <div class="text-xl">📍</div>
          <p data-t="home_info_location_label" class="text-sm text-gray-500">Location</p>
          <p data-t="home_info_location" class="font-bold">Pepsicola, Kathmandu</p>
        </div>

        <div>
          <div class="text-xl">📞</div>
          <p data-t="home_info_phone_label" class="text-sm text-gray-500">Phone</p>
          <p data-t="home_info_phone" class="font-bold">01-5923005</p>
        </div>

        <div>
          <div class="text-xl">⏰</div>
          <p data-t="home_info_time_label" class="text-sm text-gray-500">Opening Hours</p>
          <p data-t="home_info_time" class="font-bold">Mon–Sat 8AM–6PM</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="bg-slate-50 py-10 mt-10">
    <div class="container mx-auto px-4 text-center">
      <h2 data-t="home_why_title" class="mb-10 text-3xl font-bold text-clinic-slate">
        Why Choose Smart Health Clinic?
      </h2>

      <div class="grid md:grid-cols-5 gap-5">
        <!-- 1. Doctors -->
        <a
          href="/doctors"
          class="bg-white p-5 rounded-xl shadow-sm hover:shadow transition block hover:scale-105 duration-200"
        >
          <div class="text-2xl mb-2">👨‍⚕️</div>
          <p class="font-medium text-clinic-slate" data-t="home_why_1">Experienced Doctors</p>
        </a>

        <!-- 2. Facilities -->
        <a
          href="/facilities"
          class="bg-white p-5 rounded-xl shadow-sm hover:shadow transition block hover:scale-105 duration-200"
        >
          <div class="text-2xl mb-2">🏥</div>
          <p class="font-medium text-clinic-slate" data-t="home_why_2">Modern Facilities</p>
        </a>

        <!-- 3. Services -->
        <a
          href="/services"
          class="bg-white p-5 rounded-xl shadow-sm hover:shadow transition block hover:scale-105 duration-200"
        >
          <div class="text-2xl mb-2">💯</div>
          <p class="font-medium text-clinic-slate" data-t="home_why_3">Our Services</p>
        </a>

        <!-- 4. Packages -->
        <a
          href="/packages"
          class="bg-white p-5 rounded-xl shadow-sm hover:shadow transition block hover:scale-105 duration-200"
        >
          <div class="text-2xl mb-2">⚡</div>
          <p class="font-medium text-clinic-slate" data-t="home_why_4">Health Packages</p>
        </a>

        <!-- 5. Community Engagement (Scroll Link) -->
        <a
          href="#community-engagement"
          class="bg-white p-5 rounded-xl shadow-sm hover:shadow transition block hover:scale-105 duration-200"
        >
          <div class="text-2xl mb-2">🤝</div>
          <p class="font-medium text-clinic-slate" data-t="home_why_5">Community Engagement</p>
        </a>
      </div>
    </div>
  </section>

  <!-- DOCTORS -->
  <!-- <section class="py-12 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-clinic-slate mb-6">Meet Our Doctors</h2>

      <DoctorSlider showDetails={true} />
    </div>
  </section> -->

  <!-- IMPACT -->
  <section class="py-10 bg-gray-50 text-center">
    <div class="container mx-auto px-4">
      <h2 data-t="home_impact_title" class="mb-3 text-3xl font-bold text-clinic-slate">
        Trusted Healthcare in Kathmandu
      </h2>

      <p data-t="home_impact_desc" class="mb-10 text-gray-600 max-w-2xl mx-auto">
        We provide quality healthcare services to thousands of patients in Kathmandu and surrounding
        areas.
      </p>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="bg-white rounded-2xl shadow-sm p-6">
          <div class="text-3xl font-bold text-clinic-slate">800+</div>
          <div data-t="home_impact_card1" class="mt-1 text-gray-600">Patients Served</div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6">
          <div class="text-3xl font-bold text-clinic-slate">18,000+</div>
          <div data-t="home_impact_card2" class="mt-1 text-gray-600">Consultations</div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6">
          <div class="text-3xl font-bold text-clinic-slate">10,000+</div>
          <div data-t="home_impact_card3" class="mt-1 text-gray-600">Tests Done</div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm p-6">
          <div class="text-3xl font-bold text-clinic-slate">1,000+</div>
          <div data-t="home_impact_card4" class="mt-1 text-gray-600">Happy Families</div>
        </div>
      </div>
    </div>
  </section>

  <div id="community-engagement"></div>
  <section class="py-10 bg-white">
    <div class="container mx-auto px-6 max-w-6xl text-center">
      <h2 data-t="community_blood_title" class="text-3xl font-bold text-clinic-slate"></h2>

      <p data-t="community_blood_desc" class="text-gray-600 mt-3 max-w-2xl mx-auto"></p>

      <div class="mt-10">
        <ImageSlider images={bloodDonationImages} />
      </div>
    </div>
  </section>

  <!-- <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl text-center">
      <h2 data-t="community_camp_title" class="text-3xl font-bold text-clinic-slate"></h2>

      <p data-t="community_camp_desc" class="text-gray-600 mt-3 max-w-2xl mx-auto"></p>

      <div class="mt-10 ">
        {healthCampImages.map((img) => <img src={img} class="w-full h-64 object-cover" />)}
      </div>
    </div>
  </section> -->

  <section class="py-10 bg-white">
    <div class="container mx-auto px-6 max-w-6xl text-center">
      <h2 data-t="community_women_title" class="text-3xl font-bold text-clinic-slate"></h2>

      <p data-t="community_women_desc" class="text-gray-600 mt-3 max-w-2xl mx-auto"></p>

      <div class="mt-10">
        <ImageSlider images={womenCampImages} />
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-10 bg-clinic-slate text-white text-center">
    <div class="container mx-auto px-6 max-w-3xl">
      <h2 data-t="home_cta_join" class="mb-3 text-3xl font-bold">Book Your Appointment Today</h2>

      <p data-t="home_cta_desc" class="mb-6 text-slate-200">
        Get quality healthcare from experienced doctors at Smart Health Clinic.
      </p>

      <a
        href="https://vendor.smarthealthnepal.com/"
        target="_blank"
        rel="noopener"
        class="bg-clinic-teal px-7 py-3 rounded-full font-bold inline-block"
      >
        <span data-t="home_cta_main">Book Now</span>
      </a>
    </div>
  </section>
</Layout>
