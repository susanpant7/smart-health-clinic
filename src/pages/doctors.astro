---
import Layout from '../layouts/Layout.astro';
import DoctorSlider from '../components/DoctorSlider.astro';
import doctors from '../data/doctors.json';
---

<Layout
  title="Our Doctors | Smart Health Clinic"
  description="Meet experienced doctors at Smart Health Clinic in Kathmandu."
>
  <!-- HERO -->
  <section class="bg-clinic-slate text-white py-20">
    <div class="container mx-auto px-6 max-w-5xl text-center">
      <h1 data-t="doctors_hero_title" class="text-4xl md:text-6xl font-black mb-6"></h1>

      <p data-t="doctors_hero_desc" class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto"></p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <h2 data-t="doctors_intro_title" class="text-3xl font-bold text-clinic-slate mb-4"></h2>

      <p data-t="doctors_intro_desc" class="text-gray-600 leading-relaxed"></p>
    </div>
  </section>

  <!-- SLIDER -->
  <DoctorSlider showDetails={true} />

  <!-- MEET THE TEAM -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl">
      <h2
        data-t="doctors_team_title"
        class="text-3xl font-bold text-center text-clinic-slate mb-10"
      >
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {
          doctors.map((doc) => (
            <div class="relative group text-center bg-white rounded-xl p-4 shadow-sm hover:shadow-md transition">
              <div class="relative">
                <img
                  src={`/images/doctors/dp/${doc.image}`}
                  alt={doc.name.en}
                  class="w-32 h-32 mx-auto rounded-full object-cover"
                  onerror="this.onerror=null; this.src='/images/doctors/dp/default.png'"
                  loading="lazy"
                />

                <div class="absolute inset-0 bg-black/80 text-white text-xs p-3 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                  <p
                    data-en={doc.description.en}
                    data-ne={doc.description.ne}
                    data-i18n="description"
                    class="line-clamp-6"
                  >
                    {doc.description.en}
                  </p>
                </div>
              </div>

              <h3
                class="mt-3 font-semibold"
                data-i18n="name"
                data-value-en={doc.name.en}
                data-value-ne={doc.name.ne}
              >
                {doc.name.en}
              </h3>

              <p
                class="text-sm text-gray-500"
                data-i18n="specialty"
                data-value-en={doc.specialty.en}
                data-value-ne={doc.specialty.ne}
              >
                {doc.specialty.en}
              </p>

              <p
                class="text-xs text-gray-500 mt-1"
                data-i18n="schedule"
                data-value-en={doc.schedule.en}
                data-value-ne={doc.schedule.ne}
              >
                {doc.schedule.en}
              </p>

              <p class="text-xs text-gray-600 mt-1" >{doc.qualification}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-clinic-slate text-white text-center">
    <div class="container mx-auto px-6 max-w-3xl">
      <h2 data-t="doctors_cta_title" class="text-3xl font-bold mb-4"></h2>

      <p data-t="doctors_cta_desc" class="text-slate-300 mb-8"></p>

      <a
        href="https://vendor.smarthealthnepal.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-clinic-teal px-7 py-3 rounded-full font-bold inline-block"
      >
        <span data-t="doctors_cta_btn"></span>
      </a>
    </div>
  </section>
</Layout>
