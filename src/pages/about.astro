---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About Us | Smart Health Clinic"
  description="Learn about Smart Health Clinic, our mission, values, and commitment to quality healthcare in Kathmandu."
>
  <!-- HERO -->
  <section class="bg-clinic-slate py-20 text-white">
    <div class="container mx-auto px-6 max-w-5xl text-center">
      <div
        class="mb-6 inline-flex items-center rounded-full bg-clinic-teal/20 px-4 py-2 text-sm font-bold text-clinic-teal ring-1 ring-clinic-teal/30"
      >
        <span data-t="about_established"></span>
      </div>

      <h1 data-t="about_title" class="mb-6 text-4xl md:text-6xl font-black"></h1>

      <p data-t="about_who_1" class="text-lg md:text-xl leading-relaxed text-slate-200 mb-4"></p>

      <p data-t="about_who_2" class="text-base md:text-lg text-slate-400 max-w-3xl mx-auto"></p>
    </div>
  </section>

  <!-- OVERVIEW -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-12">
        <h2 data-t="about_overview_title" class="text-3xl md:text-4xl font-bold text-clinic-slate">
        </h2>
        <p data-t="about_overview_subtitle" class="text-gray-600 mt-2"></p>
      </div>

      <div
        class="bg-slate-50 rounded-3xl p-8 md:p-10 shadow-sm border space-y-6 text-gray-700 leading-relaxed"
      >
        <p data-t="about_overview_p1"></p>

        <p data-t="about_overview_p2"></p>

        <p data-t="about_overview_p3"></p>

        <div>
          <p data-t="about_overview_list_title" class="font-semibold mb-2"></p>
          <ul class="space-y-2">
            <li data-t="about_overview_li1"></li>
            <li data-t="about_overview_li2"></li>
            <li data-t="about_overview_li3"></li>
            <li data-t="about_overview_li4"></li>
          </ul>
        </div>

        <p data-t="about_overview_quote" class="pt-4 font-bold text-clinic-teal text-lg"></p>
      </div>
    </div>
  </section>

  <!-- MISSION / VISION -->
  <section class="bg-slate-50 py-20">
    <div class="container mx-auto px-6 grid gap-8 md:grid-cols-2 max-w-6xl">
      <div
        class="bg-white rounded-3xl p-8 shadow-sm border-t-4 border-clinic-teal hover:shadow-md transition"
      >
        <div class="text-4xl mb-4">🎯</div>
        <h3 data-t="about_mission_title" class="text-2xl font-bold mb-3"></h3>
        <p data-t="about_mission_desc" class="text-gray-600 leading-relaxed"></p>
      </div>

      <div
        class="bg-white rounded-3xl p-8 shadow-sm border-t-4 border-clinic-slate hover:shadow-md transition"
      >
        <div class="text-4xl mb-4">👁️</div>
        <h3 data-t="about_vision_title" class="text-2xl font-bold mb-3"></h3>
        <p data-t="about_vision_desc" class="text-gray-600 leading-relaxed"></p>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-20">
    <div class="container mx-auto px-6 text-center max-w-6xl">
      <h2
        data-t="about_values_title"
        class="text-3xl md:text-4xl font-bold mb-12 text-clinic-slate"
      >
      </h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="p-6 rounded-2xl bg-white shadow-sm border hover:shadow-md transition">
          <div class="text-3xl mb-2">❤️</div>
          <h4 data-t="about_val1_t" class="font-bold"></h4>
          <p data-t="about_val1_d" class="text-sm text-gray-500 mt-2"></p>
        </div>

        <div class="p-6 rounded-2xl bg-white shadow-sm border hover:shadow-md transition">
          <div class="text-3xl mb-2">⭐</div>
          <h4 data-t="about_val2_t" class="font-bold"></h4>
          <p data-t="about_val2_d" class="text-sm text-gray-500 mt-2"></p>
        </div>

        <div class="p-6 rounded-2xl bg-white shadow-sm border hover:shadow-md transition">
          <div class="text-3xl mb-2">🤝</div>
          <h4 data-t="about_val3_t" class="font-bold"></h4>
          <p data-t="about_val3_d" class="text-sm text-gray-500 mt-2"></p>
        </div>

        <div class="p-6 rounded-2xl bg-white shadow-sm border hover:shadow-md transition">
          <div class="text-3xl mb-2">🏡</div>
          <h4 data-t="about_val4_t" class="font-bold"></h4>
          <p data-t="about_val4_d" class="text-sm text-gray-500 mt-2"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- IMPACT -->
  <section class="bg-clinic-slate py-20 text-white">
    <div class="container mx-auto px-6 text-center max-w-6xl">
      <h2 data-t="about_impact_title" class="text-3xl md:text-4xl font-bold mb-4"></h2>

      <p data-t="about_impact_desc" class="text-slate-300 mb-10 max-w-2xl mx-auto"></p>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="p-6">
          <div class="text-3xl">👥</div>
          <p data-t="about_stat1" class="mt-3 font-bold text-clinic-teal"></p>
        </div>

        <div class="p-6">
          <div class="text-3xl">🏕️</div>
          <p data-t="about_stat2" class="mt-3 font-bold text-clinic-teal"></p>
        </div>

        <div class="p-6">
          <div class="text-3xl">🩺</div>
          <p data-t="about_stat3" class="mt-3 font-bold text-clinic-teal"></p>
        </div>

        <div class="p-6">
          <div class="text-3xl">📚</div>
          <p data-t="about_stat4" class="mt-3 font-bold text-clinic-teal"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMUNITY -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- LEFT -->
        <div>
          <h2
            data-t="about_community_title"
            class="text-3xl md:text-4xl font-bold mb-4 text-clinic-slate"
          >
          </h2>

          <p data-t="about_community_desc" class="text-gray-600 mb-6 leading-relaxed"></p>

          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <span class="text-clinic-teal text-lg">✓</span>
              <span data-t="about_community_li1" class="font-medium"></span>
            </li>

            <li class="flex items-start gap-3">
              <span class="text-clinic-teal text-lg">✓</span>
              <span data-t="about_community_li2" class="font-medium"></span>
            </li>

            <li class="flex items-start gap-3">
              <span class="text-clinic-teal text-lg">✓</span>
              <span data-t="about_community_li3" class="font-medium"></span>
            </li>

            <li class="flex items-start gap-3">
              <span class="text-clinic-teal text-lg">✓</span>
              <span data-t="about_community_li4" class="font-medium"></span>
            </li>
          </ul>
        </div>

        <!-- RIGHT -->
        <div class="relative">
          <div
            class="bg-clinic-teal text-white p-10 md:p-14 rounded-3xl shadow-xl text-center relative overflow-hidden"
          >
            <div class="absolute inset-0 opacity-10 bg-white blur-2xl"></div>

            <p
              data-t="about_quote"
              class="text-2xl md:text-4xl font-black italic leading-snug relative z-10"
            >
            </p>

            <p data-t="about_quote_sub" class="mt-6 text-white/80 text-sm relative z-10"></p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
