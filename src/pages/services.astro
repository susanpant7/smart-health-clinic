
---
import Layout from '../layouts/Layout.astro';
import { service_images } from '../data/services-images';
---

<Layout>

  <!-- HERO -->
  <section class="bg-clinic-slate text-white py-20">
    <div class="container mx-auto px-6 max-w-5xl text-center">

      <h1 class="text-4xl md:text-6xl font-black mb-6">
        Our Services
      </h1>

      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto">
        Comprehensive healthcare services designed for quality, affordability, and convenience.
      </p>

    </div>
  </section>



  <!-- SMART HEALTH DESK -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl">

      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-clinic-slate">
          Smart Health Desk
        </h2>
        <p class="text-gray-600 mt-2">
          Primary care support & discounted health services
        </p>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 items-center">

        <!-- IMAGE -->
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/images/smart-health-desk.jpeg" alt="Smart Health Desk" class="w-full h-auto" />
        </div>

        <!-- FEATURES -->
        <div class="space-y-4">

          <div class="flex items-start gap-3">
            <span class="text-clinic-teal font-bold">✓</span>
            <p>Blood Pressure Monitoring</p>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-clinic-teal font-bold">✓</span>
            <p>Lab Sample Collection</p>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-clinic-teal font-bold">✓</span>
            <p>Home Delivery & Home Collection</p>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-clinic-teal font-bold">✓</span>
            <p>Oxygen Service & Nebulizer Support</p>
          </div>

          <div class="flex items-start gap-3">
            <span class="text-clinic-teal font-bold">✓</span>
            <p>Primary Medication Assistance</p>
          </div>

          <a href="/book"
             class="inline-block mt-6 bg-clinic-teal text-white px-6 py-3 rounded-full font-bold">
            Book Smart Health Desk
          </a>

        </div>

      </div>

    </div>
  </section>

<!-- ADVANCED SERVICES -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-6 max-w-6xl">

    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-clinic-slate">
        Advanced Medical Services
      </h2>
      <p class="text-gray-600 mt-2">
        Specialized care with modern diagnostic and treatment facilities
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">

      <!-- Consultation -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border hover:shadow-md transition">
        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
          🩺 General & Specialist Consultation
        </h3>
        <ul class="space-y-2 text-gray-700">
          <li>• Pediatric</li>
          <li>• Gynecology</li>
          <li>• Cardiology</li>
          <li>• Orthopedics</li>
          <li>• Dermatology</li>
          <li>• Psychiatry</li>
        </ul>
      </div>

      <!-- Diagnostics -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border hover:shadow-md transition">
        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
          🔬 Diagnostic Services
        </h3>
        <ul class="space-y-2 text-gray-700">
          <li>• 4D Ultrasound</li>
          <li>• Digital X-ray</li>
          <li>• ECG / ECHO</li>
          <li>• Lab Tests (50+ packages)</li>
        </ul>
      </div>

      <!-- Minor OT -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border hover:shadow-md transition">
        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
          🔧 Minor OT Services
        </h3>
        <ul class="space-y-2 text-gray-700">
          <li>• Lipoma / Cyst Removal</li>
          <li>• Abscess Drainage</li>
          <li>• Suturing</li>
          <li>• Ingrown Nail Treatment</li>
          <li>• Biopsy</li>
        </ul>
      </div>

      <!-- Advanced -->
      <div class="bg-white rounded-2xl p-6 shadow-sm border hover:shadow-md transition">
        <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
          🧪 Advanced Services
        </h3>
        <ul class="space-y-2 text-gray-700">
          <li>• Endoscopy <span class="text-red-500 font-bold">(NEW 🔥)</span></li>
          <li>• Day Care & Emergency</li>
          <li>• Dressing & Injection</li>
        </ul>
      </div>

    </div>

  </div>
</section>

<!-- SERVICES IMAGE GALLERY -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-6 max-w-6xl">

    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-clinic-slate">
        Our Clinic in Action
      </h2>
      <p class="text-gray-600 mt-2">
        Smart Health Desk mobile experience
      </p>
    </div>

    <!-- TITLE IMAGE (FULL WIDTH) -->
    <div class="mb-8 rounded-2xl overflow-hidden shadow-md bg-slate-50 flex justify-center p-4">
      <img
        src={service_images[0]}
        alt="App Title Screen"
        class="h-40 md:h-56 w-auto object-contain"
      />
    </div>

    <!-- SCREENSHOTS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      {service_images.slice(1).map((img) => (
        <div class="rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition bg-slate-50 flex justify-center p-4">
          <img
            src={img}
            alt="App Screenshot"
            class="h-[420px] w-auto object-contain"
          />
        </div>
      ))}

    </div>

  </div>
</section>

  <!-- MAIN SERVICES -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 max-w-6xl">

      <h2 class="text-3xl font-bold text-center text-clinic-slate mb-12">
        Core Medical Services
      </h2>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">🩺</div>
          <h3 class="font-bold mb-2">General Checkup</h3>
          <p class="text-gray-600 text-sm">Routine health consultation and diagnosis.</p>
        </div>

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">🧪</div>
          <h3 class="font-bold mb-2">Lab Testing</h3>
          <p class="text-gray-600 text-sm">Accurate pathology and diagnostic tests.</p>
        </div>

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">💉</div>
          <h3 class="font-bold mb-2">Vaccination</h3>
          <p class="text-gray-600 text-sm">Safe immunization services for all ages.</p>
        </div>

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">🩹</div>
          <h3 class="font-bold mb-2">Wound Dressing</h3>
          <p class="text-gray-600 text-sm">All types of dressing and minor care.</p>
        </div>

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">🌬️</div>
          <h3 class="font-bold mb-2">Nebulizer Service</h3>
          <p class="text-gray-600 text-sm">Respiratory treatment support.</p>
        </div>

        <div class="p-6 border rounded-2xl shadow-sm hover:shadow-md transition">
          <div class="text-3xl mb-3">🏠</div>
          <h3 class="font-bold mb-2">Home Services</h3>
          <p class="text-gray-600 text-sm">Home sample collection and delivery.</p>
        </div>

      </div>

    </div>
  </section>


  <!-- DISCOUNT / MEMBERSHIP -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-6 max-w-6xl text-center">

      <h2 class="text-3xl font-bold text-clinic-slate mb-10">
        Smart Health Discount Card
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="p-6 border rounded-2xl">
          <p class="text-2xl font-bold text-clinic-teal">15%</p>
          <p class="text-gray-600 mt-2">Pathology Lab</p>
        </div>

        <div class="p-6 border rounded-2xl">
          <p class="text-2xl font-bold text-clinic-teal">15%</p>
          <p class="text-gray-600 mt-2">X-Ray</p>
        </div>

        <div class="p-6 border rounded-2xl">
          <p class="text-2xl font-bold text-clinic-teal">12%</p>
          <p class="text-gray-600 mt-2">Medicine</p>
        </div>

        <div class="p-6 border rounded-2xl">
          <p class="text-2xl font-bold text-clinic-teal">FREE</p>
          <p class="text-gray-600 mt-2">Home Service</p>
        </div>

      </div>

    </div>
  </section>


  <!-- CTA -->
  <section class="py-20 bg-clinic-slate text-white text-center">
    <div class="container mx-auto px-6 max-w-3xl">

      <h2 class="text-3xl font-bold mb-4">
        Need Medical Assistance?
      </h2>

      <p class="text-slate-300 mb-8">
        Book your appointment or visit Smart Health Clinic today.
      </p>

      <a 
      href="https://vendor.smarthealthnepal.com/"
  target="_blank"
  rel="noopener noreferrer"
         class="bg-clinic-teal px-7 py-3 rounded-full font-bold inline-block">
        Book Appointment
      </a>

    </div>
  </section>

</Layout>