---
import Layout from "../layouts/Layout.astro";
---

<Layout>

  <!-- HERO -->
  <section class="bg-clinic-slate text-white py-20">
    <div class="container mx-auto px-6 max-w-5xl text-center">

      <h1 class="text-4xl md:text-6xl font-black mb-6">
        Health Packages
      </h1>

      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto">
        Affordable preventive health checkups designed to keep you and your family safe and healthy.
      </p>

    </div>
  </section>


  <!-- INTRO -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-4xl text-center">

      <h2 class="text-3xl font-bold text-clinic-slate mb-4">
        Preventive Care Made Simple
      </h2>

      <p class="text-gray-600 leading-relaxed">
        Early detection saves lives. Our health packages include essential diagnostic tests at affordable prices
        so you can monitor your health regularly without financial stress.
      </p>

    </div>
  </section>


  <!-- PACKAGES -->
  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl">

      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-clinic-slate">
          Available Packages
        </h2>
        <p class="text-gray-600 mt-2">
          Choose the right package for your health needs
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">

        <!-- BASIC CHECKUP -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border hover:shadow-lg transition">

          <div class="text-4xl mb-4">🎉</div>

          <h3 class="text-2xl font-bold text-clinic-slate mb-3">
            Whole Body Checkup
          </h3>

          <p class="text-gray-600 mb-4">
            Comprehensive health screening for early detection and prevention.
          </p>

          <ul class="space-y-2 text-gray-700 mb-6">
            <li>✔ 40+ Diagnostic Tests</li>
            <li>✔ Blood & Urine Analysis</li>
            <li>✔ Liver & Kidney Function Tests</li>
            <li>✔ Diabetes Screening</li>
            <li>✔ Lipid Profile</li>
          </ul>

          <div class="flex items-center justify-between">
            <p class="text-2xl font-bold text-clinic-teal">
              Rs. 2950
            </p>

           
          </div>

        </div>


        <!-- FESTIVAL OFFER -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border hover:shadow-lg transition relative overflow-hidden">

          <!-- badge -->
          <div class="absolute top-4 right-4 bg-red-500 text-white text-xs px-3 py-1 rounded-full font-bold">
            LIMITED OFFER
          </div>

          <div class="text-4xl mb-4">🎊</div>

          <h3 class="text-2xl font-bold text-clinic-slate mb-3">
            Festival Offer Package
          </h3>

          <p class="text-gray-600 mb-4">
            Special discounted health package for complete seasonal health screening.
          </p>

          <ul class="space-y-2 text-gray-700 mb-6">
            <li>✔ 50+ Advanced Tests</li>
            <li>✔ Full Body Screening</li>
            <li>✔ Cardiac Risk Check</li>
            <li>✔ Liver & Kidney Panel</li>
            <li>✔ Diabetes + Thyroid Test</li>
          </ul>

          <div class="flex items-center justify-between">
            <p class="text-2xl font-bold text-clinic-teal">
              Rs. 2999
            </p>

           
          </div>

        </div>

      </div>

    </div>
  </section>


  <!-- CTA -->
  <section class="py-20 bg-clinic-slate text-white text-center">
    <div class="container mx-auto px-6 max-w-3xl">

      <h2 class="text-3xl font-bold mb-4">
        Take Control of Your Health Today
      </h2>

      <p class="text-slate-300 mb-8">
        Book your health package and get timely diagnosis and prevention care.
      </p>

      <a href="/book"
         class="bg-clinic-teal px-7 py-3 rounded-full font-bold inline-block">
        Book Appointment
      </a>

    </div>
  </section>

</Layout>