---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Health Packages | Smart Health Clinic"
  description="Affordable health check-up packages at Smart Health Clinic Kathmandu."
>
  <!-- HERO -->
  <section class="bg-clinic-slate text-white py-10">
    <div class="container mx-auto px-6 max-w-5xl text-center">
      <h1 data-t="package_hero_title" class="text-4xl md:text-6xl font-black mb-6"></h1>

      <p data-t="package_hero_desc" class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto"></p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <h2 data-t="package_intro_title" class="text-3xl font-bold text-clinic-slate mb-4"></h2>

      <p data-t="package_intro_desc" class="text-gray-600 leading-relaxed"></p>
    </div>
  </section>

  <!-- PACKAGES -->
  <section class="py-10 bg-slate-50">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="text-center mb-12">
        <h2 data-t="package_section_title" class="text-3xl font-bold text-clinic-slate"></h2>

        <p data-t="package_section_subtitle" class="text-gray-600 mt-2"></p>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <!-- PACKAGE 1 -->
        <div class="bg-white rounded-3xl p-8 shadow-sm border hover:shadow-lg transition">
          <div class="text-4xl mb-4">🎉</div>

          <h3 data-t="package_1_title" class="text-2xl font-bold text-clinic-slate mb-3"></h3>

          <p data-t="package_1_desc" class="text-gray-600 mb-4"></p>

          <ul class="space-y-2 text-gray-700 mb-6">
            <li data-t="package_1_li1"></li>
            <li data-t="package_1_li2"></li>
            <li data-t="package_1_li3"></li>
            <li data-t="package_1_li4"></li>
            <li data-t="package_1_li5"></li>
          </ul>

          <div class="flex items-center justify-between">
            <p data-t="package_price_1" class="text-2xl font-bold text-clinic-teal"></p>
          </div>
        </div>

        <!-- PACKAGE 2 -->
        <div
          class="bg-white rounded-3xl p-8 shadow-sm border hover:shadow-lg transition relative overflow-hidden"
        >
          <div
            class="absolute top-4 right-4 bg-red-500 text-white text-xs px-3 py-1 rounded-full font-bold"
          >
            <span data-t="package_offer_badge"></span>
          </div>

          <div class="text-4xl mb-4">🎊</div>

          <h3 data-t="package_2_title" class="text-2xl font-bold text-clinic-slate mb-3"></h3>

          <p data-t="package_2_desc" class="text-gray-600 mb-4"></p>

          <ul class="space-y-2 text-gray-700 mb-6">
            <li data-t="package_2_li1"></li>
            <li data-t="package_2_li2"></li>
            <li data-t="package_2_li3"></li>
            <li data-t="package_2_li4"></li>
            <li data-t="package_2_li5"></li>
          </ul>

          <div class="flex items-center justify-between">
            <p data-t="package_price_2" class="text-2xl font-bold text-clinic-teal"></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pt-10 bg-clinic-slate text-white text-center">
    <div class="container mx-auto px-6 max-w-3xl">
      <h2 data-t="package_cta_title" class="text-3xl font-bold mb-4"></h2>

      <p data-t="package_cta_desc" class="text-slate-300 mb-8"></p>

      <a
        href="https://vendor.smarthealthnepal.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-clinic-teal px-7 py-3 rounded-full font-bold inline-block"
      >
        <span data-t="package_cta_btn"></span>
      </a>
    </div>
  </section>
</Layout>
