---
// Changed default speed to 0.6 for a much calmer movement
const { images, title = '', speed = 0.7 } = Astro.props;
const tripledImages = [...images, ...images, ...images];
---

<div class="w-full image-slider-container py-12 bg-white" data-speed={speed}>
  {
    title && (
      <h2 class="text-3xl md:text-4xl font-bold mb-10 px-8 text-center text-slate-800">{title}</h2>
    )
  }

  <div class="relative group">
    <!-- Gradient Overlays -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 w-24 md:w-48 bg-linear-to-r from-white via-white/40 to-transparent z-10"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 w-24 md:w-48 bg-linear-to-l from-white via-white/40 to-transparent z-10"
    >
    </div>

    <!-- Scrollable Track -->
    <div
      class="slider-track flex gap-8 md:gap-12 overflow-x-auto no-scrollbar cursor-grab active:cursor-grabbing select-none px-4"
    >
      {
        tripledImages.map((img) => (
          <div class="shrink-0">
            <img
              src={img}
              class="h-75 md:h-112.5 w-auto object-cover rounded-xl shadow-sm pointer-events-none border border-slate-100 opacity-90 hover:opacity-100 transition-opacity duration-500"
              alt="Slider Content"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .slider-track {
    scroll-behavior: auto;
    /* This ensures the movement doesn't jitter at slow speeds */
    perspective: 1000px;
    backface-visibility: hidden;
  }
</style>

<script>
  const containers = document.querySelectorAll('.image-slider-container');

  containers.forEach((container) => {
    const track = container.querySelector('.slider-track');
    const speed = parseFloat(container.getAttribute('data-speed')) || 0.7;

    let isDown = false;
    let startX;
    let scrollLeft;
    let animationId;
    // Using a high-precision float for sub-pixel scrolling
    let currentX = 0;

    const animate = () => {
      if (!isDown) {
        currentX += speed;
        track.scrollLeft = currentX;

        const sectionWidth = track.scrollWidth / 3;

        // Loop logic
        if (track.scrollLeft >= sectionWidth * 2) {
          currentX -= sectionWidth;
          track.scrollLeft = currentX;
        } else if (track.scrollLeft <= 0) {
          currentX += sectionWidth;
          track.scrollLeft = currentX;
        }
      }
      animationId = requestAnimationFrame(animate);
    };

    const getX = (e) => e.pageX || e.touches[0].pageX;

    const startDragging = (e) => {
      isDown = true;
      startX = getX(e) - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    };

    const stopDragging = () => {
      isDown = false;
      // Sync our internal tracker with the manual position
      currentX = track.scrollLeft;
    };

    const move = (e) => {
      if (!isDown) return;
      const x = getX(e) - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    };

    track.addEventListener('mousedown', startDragging);
    track.addEventListener('mouseleave', stopDragging);
    track.addEventListener('mouseup', stopDragging);
    track.addEventListener('mousemove', move);

    track.addEventListener('touchstart', startDragging, { passive: true });
    track.addEventListener('touchend', stopDragging);
    track.addEventListener('touchmove', move, { passive: false });

    // Set initial position and tracker
    const init = () => {
      const startPos = track.scrollWidth / 3;
      track.scrollLeft = startPos;
      currentX = startPos;
      animate();
    };

    // Wait for images to load to get correct scrollWidth
    if (document.readyState === 'complete') {
      init();
    } else {
      window.addEventListener('load', init);
    }
  });
</script>
