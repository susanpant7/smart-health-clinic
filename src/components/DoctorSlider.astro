---
import { doctors } from "../data/doctors";

const { showDetails = false } = Astro.props;
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">

    <h2 
      data-t="doctors_title"
      class="text-center text-3xl font-bold text-clinic-slate mb-4">
    </h2>

    {showDetails && (
      <p 
        data-t="doctors_desc"
        class="mb-8 text-gray-600 max-w-2xl mx-auto text-center">
      </p>
    )}

    <div class="swiper doctorSwiper max-w-6xl mx-auto">
      <div class="swiper-wrapper">

        {doctors.map((doc) => (
          <div class="swiper-slide !h-auto">
            <div class="rounded-2xl overflow-hidden shadow-md mx-2 bg-slate-50">

              <!-- IMAGE -->
              <div class="h-96 w-full flex items-center justify-center p-3">
                <img
                  src={doc.image}
                  class="h-full w-full object-contain"
                  alt={doc.name}
                />
              </div>

              <!-- DETAILS -->
              {showDetails && (
                <div class="p-4 text-center">
                  <h3 class="font-bold text-lg">{doc.name}</h3>
                  {doc.specialty && (
                    <p class="text-gray-500 text-sm">{doc.specialty}</p>
                  )}
                </div>
              )}

            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>

<script is:inline>
  window.addEventListener("load", async () => {
    const { default: Swiper } = await import(
      "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs"
    );

    new Swiper(".doctorSwiper", {
      loop: true,
      autoplay: {
        delay: 0,
        disableOnInteraction: false,
      },
      speed: 4000,
      spaceBetween: 25,
      slidesPerView: 1.1,
      breakpoints: {
        640: { slidesPerView: 1.5 },
        768: { slidesPerView: 2 },
        1024: { slidesPerView: 2 }
      }
    });
  });
</script>