---
import { doctors } from "../data/doctors";
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
/>

<section class="py-20 bg-white">
  <div class="container mx-auto px-4">

    <h2 class="text-center text-3xl font-bold text-clinic-slate mb-12">
      Our Doctors
    </h2>

    <div class="swiper doctorSwiper max-w-6xl mx-auto">
      <div class="swiper-wrapper">

        {doctors.map((doc) => (
          <div class="swiper-slide !h-auto">
            <div class="rounded-2xl overflow-hidden shadow-md mx-2 bg-slate-50">

              <!-- IMAGE ONLY -->
              <div class="h-96 w-full flex items-center justify-center p-3">
                <img
                  src={doc.image}
                  class="h-full w-full object-contain"
                  alt={doc.name}
                />
              </div>

            </div>
          </div>
        ))}

      </div>
    </div>

  </div>
</section>

<!-- SWIPER -->
<script is:inline>
  window.addEventListener("load", async () => {
    const { default: Swiper } = await import(
      "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.mjs"
    );

    new Swiper(".doctorSwiper", {
      loop: true,

      // 🔥 CONTINUOUS SMOOTH AUTO SLIDE
      autoplay: {
        delay: 0,              // no pause
        disableOnInteraction: false,
      },

      speed: 4000,            // slow smooth movement
      spaceBetween: 25,

      // RESPONSIVE
      slidesPerView: 1.1,
      breakpoints: {
        640: { slidesPerView: 1.5 },
        768: { slidesPerView: 2 },
        1024: { slidesPerView: 2 }
      }
    });
  });
</script>